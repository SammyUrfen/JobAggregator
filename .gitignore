profile.yaml

# ── Runtime data (DB, generated feed, logs) — never commit ──
data/*
!data/.gitkeep

# ── Editor / OS / tooling ──
.vscode/
.idea/
*.swp
.DS_Store
.serena/

# ── Scratch / verification artifacts (Playwright MCP snapshots, throwaway screenshots) ──
.playwright-mcp/
/*.png
/*.jpg
