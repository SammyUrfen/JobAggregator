# Copy to `.env` and fill in. Secrets NEVER live in the DB config row (see PLAN.md §5).
# The app loads this via python-dotenv on startup.

# ── Adzuna (free tier; register at https://developer.adzuna.com) ──
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# ── Jooble (free key, approval-gated; https://jooble.org/api/about) ──
JOOBLE_API_KEY=

# ── Telegram notifications (create a bot via @BotFather; get chat_id from getUpdates) ──
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Email notifications (defaults to a local opensmtpd relay on localhost:25) ──
SMTP_HOST=localhost
SMTP_PORT=25
SMTP_USER=
SMTP_PASSWORD=

# ── Optional overrides (paths.py falls back to sensible defaults if unset) ──
# JOBAGG_DATA_DIR=./data
# JOBAGG_DB_PATH=./data/jobs.db
# JOBAGG_LOG_LEVEL=INFO
