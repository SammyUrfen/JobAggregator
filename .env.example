# Copy to `.env` and fill in. Secrets NEVER live in the DB config row (see PLAN.md §5).
# The app loads this via python-dotenv on startup.

# ── Adzuna (free tier; register at https://developer.adzuna.com) ──
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# ── Jooble (free key, approval-gated; https://jooble.org/api/about) ──
JOOBLE_API_KEY=

# ── Telegram notifications (create a bot via @BotFather; get chat_id from getUpdates) ──
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Email notifications (defaults to a local opensmtpd relay on localhost:25) ──
SMTP_HOST=localhost
SMTP_PORT=25
SMTP_USER=
SMTP_PASSWORD=

# ── Apply agent (Track D; opt-in — only needed if you `pip install -e '.[apply]'`) ──
# Encrypts saved browser logins at rest. Generate ONCE and keep it stable:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
JOBAGG_SESSION_KEY=
# The LLM (résumé tailoring + form-fill grounding) is chosen by `resume.backend` in the CONFIG,
# NOT here. With resume.backend=coding_agent (Claude Code `claude -p`) NO API key is needed.
# Only set a key if you switch resume.backend to openai_compatible (var name = resume.api_key_env):
# OPENAI_API_KEY=

# ── Optional overrides (paths.py falls back to sensible defaults if unset) ──
# JOBAGG_DATA_DIR=./data
# JOBAGG_DB_PATH=./data/jobs.db
# JOBAGG_LOG_LEVEL=INFO
